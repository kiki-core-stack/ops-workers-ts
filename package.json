{
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run build:internal --outdir=./dist",
    "build:internal": "rimraf ./dist && cross-env NODE_ENV=production bun --env-file=./.env.production.local build ./src/index.ts --minify --production --target bun",
    "compile": "bun run build:internal --compile --outfile ./dist/index",
    "dev": "cross-env NODE_ENV=development bun --env-file=./.env.development.local --watch run ./src/index.ts",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@kiki-core-stack/pack": "git+https://github.com/kiki-core-stack/pack#5abbe5392faead7917f995f18e2449e74890914d",
    "@kikiutils/mongoose": "^7.0.2",
    "@kikiutils/shared": "^16.0.0",
    "consola": "^3.4.2",
    "date-fns": "^4.4.0",
    "mongoose": "^9.7.4",
    "nodemailer": "^9.0.3",
    "p-mutex": "^1.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@kikiutils/eslint-config": "^9.2.0",
    "@kikiutils/tsconfigs": "^7.0.0",
    "@types/bun": "^1.3.14",
    "@types/nodemailer": "^8.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "knip": "^6.27.0",
    "rimraf": "^6.1.3",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "bson": "7.2.0",
    "typescript": "^6.0.3"
  }
}
