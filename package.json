{
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run build:internal --outdir=./dist",
    "build:internal": "rimraf ./dist && cross-env NODE_ENV=production bun --env-file=./.env.production.local build ./src/index.ts --minify --production --target bun",
    "compile": "bun run build:internal --compile --outfile ./dist/index",
    "dev": "cross-env NODE_ENV=development bun --env-file=./.env.development.local --watch run ./src/index.ts",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@kiki-core-stack/pack": "^0.94.2",
    "@kikiutils/mongoose": "^7.0.1",
    "@kikiutils/shared": "^14.1.2",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "mongoose": "^9.2.4",
    "nodemailer": "^8.0.1",
    "p-mutex": "^1.0.0"
  },
  "devDependencies": {
    "@kikiutils/eslint-config": "^7.0.1",
    "@kikiutils/tsconfigs": "^5.1.0",
    "@types/bun": "^1.3.10",
    "@types/nodemailer": "^7.0.11",
    "cross-env": "^10.1.0",
    "knip": "^5.86.0",
    "rimraf": "^6.1.3",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  }
}
